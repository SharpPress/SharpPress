@page "/PostView"
@model SharpPress.Pages.PostViewModel
@{
    Layout = null;
    ViewData["Title"] = Model.Post?.Title ?? "Post";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="@(Model.Post?.Excerpt ?? "")" />
    @if (!string.IsNullOrEmpty(Model.Post?.FeaturedImage))
    {
        <meta property="og:image" content="@Model.Post.FeaturedImage" />
    }
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
            min-height: 100vh;
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }

        a {
            color: #818cf8;
            text-decoration: none;
            transition: color 0.2s;
        }

        a:hover {
            color: #a5b4fc;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .post-header {
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .post-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            font-size: 0.85rem;
            color: #94a3b8;
        }

        .post-meta .author {
            color: #818cf8;
            font-weight: 600;
        }

        .post-type-badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(79, 70, 229, 0.15);
            color: #818cf8;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.5px;
            line-height: 1.3;
            margin-bottom: 1rem;
        }

        .post-excerpt {
            font-size: 1.15rem;
            color: #94a3b8;
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }

        .featured-image {
            width: 100%;
            max-height: 480px;
            object-fit: cover;
            border-radius: 16px;
            margin-bottom: 3rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .post-content {
            font-size: 1.05rem;
            line-height: 1.9;
            color: #cbd5e1;
        }

        .post-content h1,
        .post-content h2,
        .post-content h3,
        .post-content h4 {
            color: #f1f5f9;
            margin-top: 2rem;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .post-content h2 { font-size: 1.75rem; }
        .post-content h3 { font-size: 1.4rem; }
        .post-content h4 { font-size: 1.15rem; }

        .post-content p {
            margin-bottom: 1.25rem;
        }

        .post-content ul,
        .post-content ol {
            margin-bottom: 1.25rem;
            padding-left: 1.5rem;
        }

        .post-content li {
            margin-bottom: 0.5rem;
        }

        .post-content blockquote {
            border-left: 4px solid #4f46e5;
            padding: 1rem 1.5rem;
            margin: 1.5rem 0;
            background: rgba(79, 70, 229, 0.06);
            border-radius: 0 8px 8px 0;
            color: #e2e8f0;
            font-style: italic;
        }

        .post-content code {
            background: rgba(255, 255, 255, 0.08);
            padding: 0.15rem 0.4rem;
            border-radius: 4px;
            font-size: 0.9em;
            color: #a5b4fc;
        }

        .post-content pre {
            background: rgba(0, 0, 0, 0.3);
            padding: 1.25rem;
            border-radius: 12px;
            overflow-x: auto;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .post-content pre code {
            background: none;
            padding: 0;
            color: #e2e8f0;
        }

        .post-content img {
            max-width: 100%;
            border-radius: 12px;
            margin: 1.5rem 0;
        }

        .post-content a {
            color: #818cf8;
            text-decoration: underline;
            text-underline-offset: 3px;
        }

        .post-content a:hover {
            color: #a5b4fc;
        }

        .post-footer {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            color: #64748b;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #94a3b8;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.2s;
        }

        .back-link:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #e2e8f0;
        }

        .not-found {
            text-align: center;
            padding: 6rem 2rem;
        }

        .not-found h1 {
            font-size: 6rem;
            color: #4f46e5;
            margin-bottom: 1rem;
        }

        .not-found p {
            color: #94a3b8;
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }

        @@media (max-width: 640px) {
            .container {
                padding: 1.5rem 1rem;
            }

            h1 {
                font-size: 1.75rem;
            }

            .post-content {
                font-size: 1rem;
            }

            .post-footer {
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    @if (Model.Post != null)
    {
        <div class="container">
            <article>
                <header class="post-header">
                    <div class="post-meta">
                        <span class="post-type-badge">@Model.Post.Type</span>
                        @if (Model.Post.PublishedAt.HasValue)
                        {
                            <time datetime="@Model.Post.PublishedAt.Value.ToString("yyyy-MM-dd")">
                                @Model.Post.PublishedAt.Value.ToString("MMMM dd, yyyy")
                            </time>
                        }
                        @if (!string.IsNullOrEmpty(Model.Post.AuthorUsername))
                        {
                            <span>by <span class="author">@Model.Post.AuthorUsername</span></span>
                        }
                    </div>
                    <h1>@Model.Post.Title</h1>
                    @if (!string.IsNullOrEmpty(Model.Post.Excerpt))
                    {
                        <p class="post-excerpt">@Model.Post.Excerpt</p>
                    }
                </header>

                @if (!string.IsNullOrEmpty(Model.Post.FeaturedImage))
                {
                    <img src="@Model.Post.FeaturedImage" alt="@Model.Post.Title" class="featured-image" />
                }

                <div class="post-content">
                    @Html.Raw(Model.Post.Content)
                </div>

                <footer class="post-footer">
                    <a href="/" class="back-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12" />
                            <polyline points="12 19 5 12 12 5" />
                        </svg>
                        Back to Home
                    </a>
                    <span>SharpPress</span>
                </footer>
            </article>
        </div>
    }
    else
    {
        <div class="not-found">
            <h1>404</h1>
            <p>Post not found or no longer available.</p>
            <a href="/" class="back-link">Go Home</a>
        </div>
    }
</body>
</html>