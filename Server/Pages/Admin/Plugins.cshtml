@page "/admin/plugins"
@model SharpPress.Pages.PluginsModel
@inject SharpPress.Services.PluginManager pluginManager
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Plugins";
}

<style>
    .plugins-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .plugins-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .plugin-card {
        background: linear-gradient(135deg, var(--bg-card), rgba(255, 255, 255, 0.03));
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        padding: 1.75rem;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .plugin-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .plugin-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 12px 40px rgba(79, 70, 229, 0.15);
        }

            .plugin-card:hover::before {
                opacity: 1;
            }

    .plugin-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .plugin-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        font-size: 1.5rem;
    }

    .plugin-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-white);
        margin-bottom: 0.25rem;
        letter-spacing: -0.3px;
    }

    .plugin-version {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .plugin-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
    }

        .plugin-status::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
            transition: background 0.3s ease;
        }

    .plugin-card.disabled .plugin-status::before {
        background: var(--text-muted);
    }

    .plugin-description {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        flex-grow: 1;
        line-height: 1.5;
    }

    .plugin-footer {
        display: flex;
        gap: 0.75rem;
        border-top: 1px solid var(--border-subtle);
        padding-top: 1rem;
        margin-top: 1rem;
    }

    .plugin-actions {
        display: flex;
        gap: 0.75rem;
        width: 100%;
    }

    .btn-plugin {
        flex: 1;
        padding: 0.75rem 1rem;
        border: none;
        border-radius: var(--radius-md);
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 40px;
        text-decoration: none;
    }

    .btn-enable {
        background: linear-gradient(135deg, var(--success), #059669);
        color: white;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

        .btn-enable:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

    .btn-disable {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.1));
        color: var(--danger);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

        .btn-disable:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(239, 68, 68, 0.15));
        }

    .plugin-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-subtle);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .plugin-card.disabled {
        opacity: 0.7;
    }

        .plugin-card.disabled .plugin-name {
            color: var(--text-muted);
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .empty-state-title {
        font-size: 1.25rem;
        color: var(--text-white);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .empty-state-text {
        font-size: 0.95rem;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-mini {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        padding: 1rem;
        text-align: center;
        transition: all 0.2s ease;
    }

        .stat-mini:hover {
            border-color: var(--primary);
            background: rgba(79, 70, 229, 0.05);
        }

    .stat-number {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--primary);
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-upload-plugin,
    .btn-install-store {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: var(--radius-md);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
        white-space: nowrap;
    }

    .btn-upload-plugin {
        background: linear-gradient(135deg, var(--primary), #6366f1);
        color: white;
        box-shadow: 0 4px 14px rgba(79, 70, 229, 0.25);
    }

        .btn-upload-plugin:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 70, 229, 0.35);
        }

    .btn-install-store {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
        color: var(--text-white);
        border: 1px solid var(--border-subtle);
    }

        .btn-install-store:hover {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05));
            border-color: var(--primary);
            transform: translateY(-2px);
        }
</style>

<div class="plugins-header">
    <div>
        <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem;">Plugin Management</h1>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Manage and control your installed plugins</p>
    </div>
    <div style="display: flex; gap: 0.75rem; align-items: center;">
        <label class="btn-upload-plugin" for="pluginFileInput">
            <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2;">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="17 8 12 3 7 8" />
                <line x1="12" y1="3" x2="12" y2="15" />
            </svg>
            Upload Plugin
        </label>
        @Html.AntiForgeryToken()
        <input type="file" id="pluginFileInput" name="pluginFile" accept=".dll" hidden onchange="handlePluginUpload(this.files)" />

        <a href="/admin/plugins/store" class="btn-install-store">
            <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2;">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
            </svg>
            Browse Store
        </a>
    </div>
</div>

@if (pluginManager.GetLoadedPlugins().Count > 0)
{
    <div class="stats-row">
        <div class="stat-mini">
            <div class="stat-number">@pluginManager.GetLoadedPlugins().Count</div>
            <div class="stat-label">Total Plugins</div>
        </div>
        <div class="stat-mini">
            <div class="stat-number">@pluginManager.GetEnabledPlugins().Count</div>
            <div class="stat-label">Active</div>
        </div>
        <div class="stat-mini">
            <div class="stat-number">@(pluginManager.GetLoadedPlugins().Count - pluginManager.GetEnabledPlugins().Count)</div>
            <div class="stat-label">Disabled</div>
        </div>
    </div>

    <div class="plugins-grid">
        @foreach (var p in pluginManager.GetLoadedPlugins())
        {
            var isEnabled = pluginManager.IsPluginEnabled(p.Value.Name);
            var statusClass = isEnabled ? "" : "disabled";
            var firstLetter = p.Value.Name.FirstOrDefault().ToString().ToUpper();

            <div class="plugin-card @statusClass">
                <div class="plugin-header">
                    <div style="flex: 1;">
                        <div class="plugin-name">@p.Value.Name</div>
                        <div class="plugin-version">v@(p.Value.Version)</div>
                    </div>
                    <div class="plugin-icon">@firstLetter</div>
                </div>

                <div class="plugin-description">
                    @(string.IsNullOrEmpty(p.Value.Description) ? "No description provided" : p.Value.Description)
                </div>

                <div class="plugin-status">
                    @if (isEnabled)
                    {
                        <span style="color: var(--success);">Active</span>
                    }
                    else
                    {
                        <span style="color: var(--text-muted);">Disabled</span>
                    }
                </div>

                <div class="plugin-footer">
                    <div class="plugin-actions">
                        @if (isEnabled)
                        {
                            <form method="post" asp-page-handler="Disable" style="flex: 1;">
                                <input name="name" value="@p.Value.Name" hidden />
                                <button class="btn-plugin btn-disable" type="submit">
                                    <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2;">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="15" y1="9" x2="9" y2="15" />
                                        <line x1="9" y1="9" x2="15" y2="15" />
                                    </svg>
                                    Disable
                                </button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Enable" style="flex: 1;">
                                <input name="name" value="@p.Value.Name" hidden />
                                <button class="btn-plugin btn-enable" type="submit">
                                    <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2;">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                    Enable
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <div class="plugin-meta">
                    <div class="meta-item">
                        <svg viewBox="0 0 24 24" style="width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.5;">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        Author
                    </div>
                    <div class="meta-item" title="@p.Value.Author">
                        @(p.Value.Author ?? "Unknown")
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-state-icon">📦</div>
            <div class="empty-state-title">No Plugins Installed</div>
            <div class="empty-state-text">Place your plugin DLL files in the plugins directory or install one from store to get started.</div>
        </div>
    </div>
}

@Html.AntiForgeryToken()
<script>
    function handlePluginUpload(files) {
        if (!files || files.length === 0) return;

        const file = files[0];

        if (!file.name.toLowerCase().endsWith('.dll')) {
            alert('Please select a valid plugin DLL file (.dll only)');
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!token) {
            alert('Security token not found. Please refresh the page.');
            return;
        }

        const formData = new FormData();
        formData.append('__RequestVerificationToken', token);
        formData.append('pluginFile', file);

        const uploadLabel = document.querySelector('.btn-upload-plugin');
        const originalText = uploadLabel.innerHTML;
        uploadLabel.innerHTML = '<svg viewBox="0 0 24 24" style="width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; animation: spin 1s linear infinite;"><circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="32" /></svg> Uploading...';
        uploadLabel.style.pointerEvents = 'none';
        uploadLabel.style.opacity = '0.7';

        fetch('?handler=Upload', {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (response.ok) {
                alert('Plugin uploaded successfully!');
                location.reload();
            } else {
                return response.text().then(text => {
                    throw new Error(text || 'Upload failed');
                });
            }
        })
        .catch(error => {
            console.error('Upload error:', error);
            alert('Failed to upload plugin: ' + error.message);

            uploadLabel.innerHTML = originalText;
            uploadLabel.style.pointerEvents = '';
            uploadLabel.style.opacity = '';

            document.getElementById('pluginFileInput').value = '';
        });
    }

    const style = document.createElement('style');
    style.textContent = `
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }`;
    document.head.appendChild(style);
</script>